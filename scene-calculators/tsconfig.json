{
  "include": ["src/**/*.ts*"],
  "exclude": ["src/build.ts", "dist/*", "node_modules"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "declarationDir": "./dist"
  }
}
